PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=converter_db
DB_USER=postgres
DB_PASSWORD=Harsh@2212

# Max parallel FFmpeg conversions (5 = good for 4-8 core CPU)
# Lower to 3 if your PC slows down; raise to 8 on a powerful machine
CONCURRENCY=5

# FFmpeg binary (installed via winget)
FFMPEG_PATH=C:/Users/harsh/AppData/Local/Microsoft/WinGet/Links/ffmpeg.exe

# YouTube bot-check fallback for yt-dlp
# Prefer cookies file mode for stable behavior on Windows.
# YTDLP_COOKIES_FILE=
# YouTube JS challenge solver settings
YTDLP_JS_RUNTIMES=node
YTDLP_REMOTE_COMPONENTS=ejs:github
# Optional browser mode (disabled by default to avoid cookie DB lock errors)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_BROWSER_FALLBACKS=edge
