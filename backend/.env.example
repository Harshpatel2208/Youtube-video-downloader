# Copy this file to .env and fill in your values
PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=converter_db
DB_USER=postgres
DB_PASSWORD=Harsh@2212

# Optional: full path to ffmpeg binary if not on system PATH
# FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe

# Optional: YouTube bot-check fallback
# Use one of these when some videos require login cookies:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Optional: additional browser fallbacks in order
# YTDLP_COOKIES_BROWSER_FALLBACKS=edge
# YTDLP_COOKIES_FILE=C:/path/to/cookies.txt

# Optional: YouTube JS challenge solving (recommended defaults)
# YTDLP_JS_RUNTIMES=node
# YTDLP_REMOTE_COMPONENTS=ejs:github
